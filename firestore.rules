rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // --------------------------------------------------------------------------
    // 1. Workspace Membership Check
    // --------------------------------------------------------------------------
    function isWorkspaceMember(workspaceId) {
      return request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds;
    }

    // --------------------------------------------------------------------------
    // 2. User Profiles & Stats
    //    READ: Any authenticated user (needed for member directories & presence)
    //    WRITE: Only the profile owner
    // --------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      match /{allPaths=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // --------------------------------------------------------------------------
    // 3. Workspaces
    //    READ: Members only (joinCode is protected)
    //    UPDATE: Owner for all fields, non-members for self-join (memberIds only)
    //    CREATE: Creator must be in initial memberIds
    //    DELETE: Owner only
    // --------------------------------------------------------------------------
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.memberIds;
      allow update: if request.auth != null && (
        // Owner can update anything
        request.auth.uid == resource.data.ownerId ||
        // Non-member self-join: can ONLY append themselves to memberIds
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
          request.auth.uid in request.resource.data.memberIds
        )
      );
      allow create: if request.auth != null && request.auth.uid in request.resource.data.memberIds;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // Activity Log subcollection — members can read, write
      match /activityLog/{logId} {
        allow read, write: if request.auth != null && isWorkspaceMember(workspaceId);
      }
    }
    
    // --------------------------------------------------------------------------
    // 3b. Join Code Lookup (public read for non-members joining)
    //     Stores { code, workspaceId } — no sensitive data
    // --------------------------------------------------------------------------
    match /joinCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    
    // --------------------------------------------------------------------------
    // 4. Tasks, Projects, Tags (Secured by Workspace Membership)
    // --------------------------------------------------------------------------
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
    }
    
    match /projects/{projectId} {
      allow read, update, delete: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
    }
    
    match /tags/{tagId} {
      allow read, update, delete: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
    }
  }
}
